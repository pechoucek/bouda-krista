# Copy this to .env.local and fill in your values

# ── GoPay ──────────────────────────────────────────────────────────────────
# Create account at https://www.gopay.com and get credentials from the portal
GOPAY_GO_ID=123456789            # Your GoID (Identifikátor eshopu)
GOPAY_CLIENT_ID=your_client_id   # Client ID from GoPay portal
GOPAY_CLIENT_SECRET=your_secret  # Client secret from GoPay portal
GOPAY_SANDBOX=true               # Set to false in production

# ── Pricing ────────────────────────────────────────────────────────────────
# Nightly rate in CZK (e.g. 8000 = 8 000 Kč/night)
NIGHTLY_RATE_CZK=12000
NEXT_PUBLIC_NIGHTLY_RATE_CZK=12000

# ── Airbnb iCal ────────────────────────────────────────────────────────────
# Airbnb dashboard → each listing → Calendar → Export calendar
AIRBNB_ICAL_TINY=https://www.airbnb.com/calendar/ical/1646250768905855726.ics?t=7bb5e8f8c47e4502aba3afa812a2a611
AIRBNB_ICAL_TIMBER=https://www.airbnb.com/calendar/ical/1677566795867113387.ics?t=d9989c243e634ea9aa1e08ec3d2c0b15
AIRBNB_ICAL_TOPFLOOR=https://www.airbnb.com/calendar/ical/1681738436024240038.ics?t=c97a2b97ca5140329e1b7040d2d7b9c5
AIRBNB_ICAL_WHOLE=https://www.airbnb.com/calendar/ical/1681755602554370759.ics?t=8d72468149794309ac5548d428abbc50&locale=en-GB

# ── Email (Resend) ─────────────────────────────────────────────────────────
# https://resend.com — free tier is fine to start
RESEND_API_KEY=re_...
EMAIL_FROM=rezervace@bouda-krista.cz
OWNER_EMAIL=helena.pechouckova@gmail.com

# ── Site URL ───────────────────────────────────────────────────────────────
# No trailing slash
NEXT_PUBLIC_URL=https://bouda-krista.cz
